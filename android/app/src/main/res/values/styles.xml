<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme - No ActionBar for WebView app -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- 深色窗口背景，避免白色闪烁 -->
        <item name="android:windowBackground">#0a0a1a</item>
        <!-- Edge-to-edge support -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Action Mode 样式（文本选择模式） -->
        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeBackground">@drawable/action_mode_background</item>
        <item name="android:actionModeBackground">@drawable/action_mode_background</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- 深色窗口背景 -->
        <item name="android:windowBackground">#0a0a1a</item>
        <!-- 浮动元素背景色（如浮动工具栏） -->
        <item name="android:colorBackgroundFloating">#1a1a2e</item>
        <!-- Edge-to-edge support -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Action Mode 样式（文本选择模式） -->
        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeBackground">@drawable/action_mode_background</item>
        <item name="actionModeCloseDrawable">@android:drawable/ic_menu_close_clear_cancel</item>
        <item name="android:actionModeBackground">@drawable/action_mode_background</item>
        <item name="actionModeStyle">@style/ActionModeStyle</item>
        <item name="actionModePopupWindowStyle">@style/ActionModePopupStyle</item>
        <!-- Alert Dialog 样式 - 避免显示为 splash -->
        <item name="alertDialogTheme">@style/AppTheme.AlertDialog</item>
        <item name="android:alertDialogTheme">@style/AppTheme.AlertDialog</item>
        <!-- Popup 窗口样式 -->
        <item name="android:popupWindowStyle">@style/PopupWindowStyle</item>
    </style>

    <!-- Action Mode 样式 -->
    <style name="ActionModeStyle" parent="Widget.AppCompat.ActionMode">
        <item name="background">@drawable/action_mode_background</item>
    </style>

    <!-- Popup 窗口样式 -->
    <style name="PopupWindowStyle" parent="android:Widget.PopupWindow">
        <item name="android:popupBackground">@drawable/action_mode_background</item>
    </style>

    <!-- Action Mode Popup 样式（浮动工具栏） -->
    <style name="ActionModePopupStyle" parent="Widget.AppCompat.Light.PopupMenu">
        <item name="android:popupBackground">@drawable/action_mode_background</item>
    </style>

    <!-- 自定义 Alert Dialog 样式 -->
    <style name="AppTheme.AlertDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:background">@drawable/dialog_background</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <!-- Splash 结束后自动切换到此主题 -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <!-- Android 12+ SplashScreen API: 使用背景色 + 图标，不再使用全屏 splash 图片 -->
        <!-- 这样可以避免 Action Mode（文本选择）时背景显示 splash 图片的问题 -->
        <item name="windowSplashScreenBackground">#0a0a1a</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowBackground">#0a0a1a</item>
        <!-- Action Mode 样式 - 防止文本选择时显示错误背景 -->
        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeBackground">@drawable/action_mode_background</item>
        <item name="android:actionModeBackground">@drawable/action_mode_background</item>
        <item name="actionModePopupWindowStyle">@style/ActionModePopupStyle</item>
        <!-- 浮动元素使用深色背景 -->
        <item name="android:colorBackgroundFloating">#1a1a2e</item>
    </style>
</resources>