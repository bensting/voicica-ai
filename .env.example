# Firebase 配置
# 从 Firebase Console (https://console.firebase.google.com) 获取这些值
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Analytics (可选 - 仅在需要用户行为追踪时配置)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# 后端 API 配置
# 开发环境使用本地后端，生产环境使用实际部署的后端 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Creem 支付配置
# 支付成功后的回调 URL (用户完成支付后跳转的页面)
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
# 支付取消后的回调 URL (用户取消支付后跳转的页面，可选)
NEXT_PUBLIC_PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel
