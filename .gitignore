# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.idea

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.*.local
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map

# Build generated files
**/public/build-info.json

/src/generated/prisma

# Firebase Admin credentials
**/firebase-admin-key.json
**/*-firebase-adminsdk-*.json

.idea/encodings.xml
merge_to_main.bat

# Windows special device files (should not be created as regular files)
nul
NUL

# Capacitor native projects (build artifacts)
/ios/App/App/public
/ios/App/Pods
/android/app/src/main/assets/public
/android/.gradle
/android/app/build
/android/build

