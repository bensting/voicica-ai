generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model anonymous_users {
  user_id              String    @unique(map: "uq_anonymous_users_user_id") @db.VarChar(255)
  device_fingerprint   String    @unique(map: "uq_anonymous_users_device_fingerprint") @db.VarChar(255)
  ip_address           String?   @db.VarChar(50)
  user_agent           String?
  credits              Int
  total_credits_used   Int
  expires_at           DateTime? @db.Timestamptz(6)
  last_used_at         DateTime? @db.Timestamptz(6)
  is_anonymous         Boolean
  converted_to_user_id String?   @db.VarChar(255)
  id                   Int       @id(map: "pk_anonymous_users") @default(autoincrement())
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)

  @@index([converted_to_user_id], map: "idx_anonymous_users_converted_to_user_id")
  @@index([device_fingerprint], map: "idx_anonymous_users_device_fingerprint")
  @@index([expires_at], map: "idx_anonymous_users_expires_at")
  @@index([last_used_at], map: "idx_anonymous_users_last_used_at")
  @@index([user_id], map: "idx_anonymous_users_user_id")
}

model configs {
  key         String    @unique(map: "ix_configs_key") @db.VarChar(255)
  value       Json
  description String?
  config_type String?   @db.VarChar(50)
  version     Int
  is_active   Boolean
  id          Int       @id(map: "pk_configs") @default(autoincrement())
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([config_type], map: "ix_configs_config_type")
  @@index([is_active], map: "ix_configs_is_active")
  @@index([value], map: "ix_configs_value_gin", type: Gin)
}

model credit_history {
  user_id     String    @db.VarChar(255)
  amount      Int
  task_id     String?   @db.VarChar(255)
  description String
  id          Int       @id(map: "pk_credit_history") @default(autoincrement())
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_credit_history_created_at")
  @@index([task_id], map: "idx_credit_history_task_id")
  @@index([user_id, created_at], map: "idx_credit_history_user_created")
  @@index([user_id], map: "idx_credit_history_user_id")
}

model subscription_plans {
  platform                  String               @db.VarChar(50)
  product_type              String               @db.VarChar(50)
  product_id                String               @db.VarChar(255)
  base_plan_id              String?              @db.VarChar(255)
  plan_name                 String               @db.VarChar(100)
  display_name              Json                 @db.Json
  features                  Json                 @db.Json
  credits_per_cycle         Int
  cycle_days                Int
  active                    Boolean
  sort_order                Int
  price                     Json                 @db.Json
  discounted_price          Json                 @db.Json
  billing_period            String               @db.VarChar(20)
  enable_first_month_coupon Boolean
  first_month_coupon_id     String?              @db.VarChar(100)
  created_at                DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                DateTime             @default(now()) @db.Timestamptz(6)
  id                        Int                  @id(map: "pk_subscription_plans") @default(autoincrement())
  user_subscriptions        user_subscriptions[]

  @@index([active], map: "ix_subscription_plans_active")
  @@index([platform], map: "ix_subscription_plans_platform")
  @@index([product_id], map: "ix_subscription_plans_product_id")
}

model task_queue {
  task_id         String    @db.VarChar(255)
  task_type       String    @db.VarChar(50)
  user_id         String    @db.VarChar(255)
  status          String    @db.VarChar(20)
  priority        Int
  payload         Json      @db.Json
  retry_count     Int
  max_retries     Int
  worker_id       String?   @db.VarChar(100)
  error_message   String?
  started_at      DateTime? @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  timeout_seconds Int
  id              Int       @id(map: "pk_task_queue") @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model tts_records {
  user_id         String    @db.VarChar(255)
  task_id         String    @unique(map: "ix_tts_records_task_id") @db.VarChar(255)
  text            String
  voice_name      String    @db.VarChar(255)
  language        String?   @db.VarChar(20)
  speed           Float
  pitch           Int
  volume          Int
  credits_cost    Int
  character_count Int
  status          String    @db.VarChar(20)
  progress        Int
  audio_url       String?
  duration        Float?
  format          String    @db.VarChar(10)
  error_message   String?
  completed_at    DateTime? @db.Timestamptz(6)
  id              Int       @id(map: "pk_tts_records") @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([status], map: "ix_tts_records_status")
  @@index([user_id, created_at], map: "ix_tts_records_user_created")
  @@index([user_id], map: "ix_tts_records_user_id")
  @@index([user_id, status], map: "ix_tts_records_user_status")
  @@index([user_id, status, created_at], map: "ix_tts_records_user_status_created")
}

model user_subscriptions {
  user_id                  String             @db.VarChar(128)
  subscription_plan_id     Int
  product_id               String             @db.VarChar(255)
  product_type             String?            @db.VarChar(50)
  platform                 String?            @db.VarChar(50)
  external_transaction_id  String             @db.VarChar(255)
  external_subscription_id String?            @db.VarChar(255)
  request_id               String             @unique(map: "ix_user_subscriptions_request_id") @db.VarChar(100)
  status                   String             @db.VarChar(50)
  start_date               DateTime           @db.Timestamptz(6)
  end_date                 DateTime           @db.Timestamptz(6)
  credits_allocated        Int
  amount                   Int?
  currency                 String?            @db.VarChar(10)
  created_at               DateTime           @default(now()) @db.Timestamptz(6)
  updated_at               DateTime           @default(now()) @db.Timestamptz(6)
  activated_at             DateTime?          @db.Timestamptz(6)
  cancelled_at             DateTime?          @db.Timestamptz(6)
  cancellation_reason      String?            @db.VarChar(500)
  auto_renew               Boolean
  cancel_at_period_end     Boolean
  id                       Int                @id(map: "pk_user_subscriptions") @default(autoincrement())
  subscription_plans       subscription_plans @relation(fields: [subscription_plan_id], references: [id], onUpdate: NoAction, map: "fk_user_subscriptions_subscription_plan_id_subscription_plans")
  users                    users              @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_subscriptions_user_id_users")

  @@index([end_date], map: "ix_user_subscriptions_end_date")
  @@index([platform, external_subscription_id], map: "ix_user_subscriptions_platform_ext_sub")
  @@index([platform, external_transaction_id], map: "ix_user_subscriptions_platform_ext_txn")
  @@index([status], map: "ix_user_subscriptions_status")
  @@index([status, end_date], map: "ix_user_subscriptions_status_end_date")
  @@index([user_id], map: "ix_user_subscriptions_user_id")
  @@index([user_id, status], map: "ix_user_subscriptions_user_status")

  // 关联历史记录
  history subscription_history[]
}

/// 订阅变动历史表
model subscription_history {
  id                 Int                @id @default(autoincrement())
  subscription_id    Int
  user_id            String             @db.VarChar(128)
  event_type         String             @db.VarChar(50) // CREATED, ACTIVATED, RENEWED, CANCELLED, EXPIRED, UPDATED
  old_status         String?            @db.VarChar(50)
  new_status         String?            @db.VarChar(50)
  stripe_event_id    String?            @db.VarChar(255) // Stripe event ID for deduplication
  stripe_event_type  String?            @db.VarChar(100) // checkout.session.completed, invoice.paid, etc.
  amount             Int?               // 金额（分）
  currency           String?            @db.VarChar(10)
  credits_change     Int?               // 积分变动
  metadata           Json?              // 额外信息
  created_at         DateTime           @default(now()) @db.Timestamptz(6)

  // 关联
  subscription       user_subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@unique([stripe_event_id]) // 防止重复处理
  @@index([subscription_id], map: "ix_subscription_history_subscription_id")
  @@index([user_id], map: "ix_subscription_history_user_id")
  @@index([event_type], map: "ix_subscription_history_event_type")
  @@index([created_at], map: "ix_subscription_history_created_at")
}

model users {
  user_id            String               @unique(map: "uq_users_user_id") @db.VarChar(128)
  email              String?              @db.VarChar(255)
  name               String?              @db.VarChar(255)
  photo_url          String?              @db.VarChar(500)
  credits            Int
  total_credits_used Int
  id                 Int                  @id(map: "pk_users") @default(autoincrement())
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  user_subscriptions user_subscriptions[]

  // Auth.js User 关联
  authUser           User?

  @@index([email], map: "idx_user_email")
  @@index([user_id], map: "idx_user_id")
}

// ==================== Auth.js 表 ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // 关联到应用的 users 表
  appUserId     String?   @unique
  appUser       users?    @relation(fields: [appUserId], references: [user_id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== 应用业务表 ====================

model voices {
  name              String    @unique(map: "uq_voices_name") @db.VarChar(255)
  provider          String    @db.VarChar(50)
  locale            String    @db.VarChar(20)
  country           String    @db.VarChar(10)
  role              String    @db.VarChar(50)
  gender            String    @db.VarChar(20)
  avatar_url        String
  voice_sample_url  String
  voice_sample_text String
  tags              Json      @db.Json
  style_list        Json      @db.Json
  is_active         Boolean
  sort_order        Int
  id                Int       @id(map: "pk_voices") @default(autoincrement())
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  display_name      String?   @db.VarChar(100)

  @@index([country], map: "ix_voices_country")
  @@index([is_active], map: "ix_voices_is_active")
  @@index([locale], map: "ix_voices_locale")
  @@index([locale, is_active], map: "ix_voices_locale_active")
  @@index([name], map: "ix_voices_name")
  @@index([provider], map: "ix_voices_provider")
  @@index([provider, country], map: "ix_voices_provider_country")
  @@index([role], map: "ix_voices_role")
  @@index([role, country], map: "ix_voices_role_country")
  @@index([sort_order, is_active], map: "ix_voices_sort_active")
}
