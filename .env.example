# 应用 URL 配置
# 用于生成分享链接，开发环境设为 http://localhost:3000
NEXT_PUBLIC_APP_URL=https://voicica.ai

# Firebase 配置
# 从 Firebase Console (https://console.firebase.google.com) 获取这些值
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK 配置（服务端）
# 从 Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# 支付配置
# 支付平台选择: 'creem' 或 'stripe'
NEXT_PUBLIC_PAYMENT_PROVIDER=stripe

# 支付回调 URL 配置
# 支付成功后的回调 URL (用户完成支付后跳转的页面)
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=http://localhost:3000/studio/payment/success
# 支付取消后的回调 URL (用户取消支付后跳转的页面，可选)
NEXT_PUBLIC_PAYMENT_CANCEL_URL=http://localhost:3000/studio/payment/cancel

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

MICROSOFT_TTS_API_KEY=your_microsoft_tts_api_key_here
MICROSOFT_TTS_REGION=southeastasia

# Google Cloud TTS API Key
# 从 Google Cloud Console 获取
GOOGLE_API_KEY=your_google_api_key_here

# Fish Audio API Key
# 从 Fish Audio Dashboard (https://fish.audio) 获取
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# Auth.js
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'));" 或者 openssl rand -base64 32
AUTH_URL=http://localhost:3000
AUTH_SECRET=your_auth_secret_here

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Neon Database 配置
# 注意：添加连接池参数以避免 "Error { kind: Closed }" 错误
# pgbouncer=true - 使用 Neon 连接池
# connection_limit=1 - Serverless 环境每个函数只需 1 个连接
# pool_timeout=0 - 禁用超时，避免连接关闭错误
DATABASE_URL=postgresql://neondb_owner:your_password@your-host.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1&pool_timeout=0

# Cloudflare R2 存储配置（如果使用 cloudflare_r2 后端）
# R2 Account ID（可在 Cloudflare Dashboard 查看）
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id
# R2 API Token 的 Access Key ID
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2 API Token 的 Secret Access Key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2 Bucket 名称
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
# R2 公开访问 URL（用于公开访问文件）
# 使用 Cloudflare 提供的公共开发 URL（不含 bucket 名称，会自动拼接）
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Inngest (可选，生产环境需要，claudflare)
INNGEST_EVENT_KEY=your_inngest_event_key_here
INNGEST_SIGNING_KEY=your_inngest_signing_key_here

# YouTube Downloader Residential Proxy
# Used by youtubei.js to avoid IP blocking
# Format: http://user:pass@host:port or socks5://user:pass@host:port
YOUTUBE_PROXY_URL=

# Kie.ai API Key
# 用于 Seedance 1.5 Pro 视频生成
# 从 Kie.ai (https://kie.ai/api-key) 获取
KIE_API_KEY=your_kie_api_key_here

# Cloudflare Queue Consumer Secret（用于验证 TTS 队列消费者身份）
# 通过 wrangler secret put QUEUE_CONSUMER_SECRET 在两个 worker 上设置
QUEUE_CONSUMER_SECRET=your_queue_consumer_secret_here

# Fish Audio API Key
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# ==========================================
# Google Play Billing API 配置
# ==========================================
# 用于验证 Google Play 购买的真实性
# 需要在 Google Play Console 中配置服务账号，并授予 "财务数据" 权限
# 文档：https://developers.google.com/android-publisher/getting_started

# 应用包名
GOOGLE_PLAY_PACKAGE_NAME=ai.voicica.app

# 服务账号凭证（可选，如果不配置则使用 Firebase Admin SDK 的服务账号）
# 注意：Firebase 服务账号需要在 Google Play Console 中授权才能访问 API
# GOOGLE_PLAY_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ==========================================
# Android 签名密钥配置
# ==========================================
# 用于构建发布版 APK/AAB 的签名密钥信息
# 警告：这些是敏感信息，不要提交到 Git！
# 请在 .env.local 中配置（已在 .gitignore 中排除）

# 密钥文件路径（相对于项目根目录）
# 默认: android-release.keystore
ANDROID_KEYSTORE_PATH=android-release.keystore

# 密钥库密码（生成密钥时设置的密码）
ANDROID_KEYSTORE_PASSWORD=your_keystore_password_here

# 密钥别名（生成密钥时设置的别名）
# 默认: voicica-key
ANDROID_KEY_ALIAS=voicica-key

# 密钥密码（生成密钥时设置的密钥密码）
ANDROID_KEY_PASSWORD=your_key_password_here

# ==========================================
# Google AdSense 广告配置
# ==========================================
# 从 Google AdSense (https://www.google.com/adsense) 获取
# 发布商 ID，格式：ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# 广告单元 ID（在 AdSense 控制台创建广告单元后获取）
# 首页 TTS Samples 下方广告位
NEXT_PUBLIC_AD_SLOT_HOME_SAMPLES=xxxxxxxxxx
# 首页 CTA 下方广告位
NEXT_PUBLIC_AD_SLOT_HOME_CTA=xxxxxxxxxx
# 通用横幅广告位
NEXT_PUBLIC_AD_SLOT_BANNER=xxxxxxxxxx

# ==========================================
# Telegram Bot 配置
# ==========================================
# @VoicicaAI bot token，从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# Polygon RPC 配置
# ==========================================
# Lucky Draw 开奖使用 Polygon 链上 blockHash
# 默认使用公共 RPC，生产环境建议使用 Alchemy/Infura
POLYGON_RPC_URL=https://polygon-rpc.com
