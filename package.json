{
  "name": "ai-voices-labs-web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && wrangler dev",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "version:sync": "node scripts/sync-version.js",
    "version:patch": "npm version patch --no-git-tag-version && npm run version:sync",
    "version:minor": "npm version minor --no-git-tag-version && npm run version:sync",
    "version:major": "npm version major --no-git-tag-version && npm run version:sync",
    "native:version:sync": "node scripts/sync-native-version.js",
    "native:version:show": "node -e \"console.log(JSON.stringify(require('./src/native-version.json'), null, 2))\"",
    "android:dev": "node scripts/android-dev.js",
    "android:build": "node scripts/build-android.js apk",
    "android:build:aab": "node scripts/build-android.js aab",
    "android:build:test": "node scripts/build-android-test.js",
    "android:build:manual": "cd android && gradlew assembleRelease",
    "android:build:debug": "cd android && gradlew assembleDebug",
    "android:clean": "cd android && gradlew clean",
    "android:publish": "node scripts/upload-to-google-play.js production",
    "android:publish:internal": "node scripts/upload-to-google-play.js internal",
    "android:publish:beta": "node scripts/upload-to-google-play.js beta",
    "release:github": "node scripts/create-github-release.js",
    "release:github:draft": "node scripts/create-github-release.js --draft",
    "release:github:test": "node scripts/create-github-release.js --test",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:build": "next build && next export && npx cap sync",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "cap:dev:android": "npx cap run android --livereload --external",
    "cap:assets": "npx @capacitor/assets generate --iconBackgroundColor #9333ea --splashBackgroundColor #9333ea && node scripts/fix-pwa-icons.js",
    "cap:icons": "node scripts/generate-app-icons.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.934.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor-community/media": "^8.0.1",
    "@capacitor-firebase/analytics": "^7.4.0",
    "@capacitor-firebase/authentication": "^7.4.0",
    "@capacitor-firebase/messaging": "^7.5.0",
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/file-transfer": "^1.0.6",
    "@capacitor/filesystem": "^7.1.5",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/keyboard": "^7.0.3",
    "@capacitor/local-notifications": "^7.0.4",
    "@capacitor/share": "^7.0.3",
    "@capacitor/splash-screen": "^7.0.3",
    "@capacitor/toast": "^7.0.3",
    "@capawesome/capacitor-app-update": "^7.2.0",
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "@headlessui/react": "^2.2.9",
    "@m430/capacitor-app-install": "^0.0.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@next/third-parties": "^16.0.3",
    "axios": "^1.12.2",
    "country-flag-icons": "^1.5.21",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "ethers": "^6.16.0",
    "file-saver": "^2.0.5",
    "firebase": "^11.2.0",
    "jose": "^6.1.3",
    "jszip": "^3.10.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.546.0",
    "music-metadata": "^11.10.3",
    "nanoid": "^5.1.6",
    "next": "^15.5.7",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.3.12",
    "next-pwa": "^5.6.0",
    "openai": "^6.16.0",
    "opencc-js": "^1.0.5",
    "react": "19.1.0",
    "react-datepicker": "^8.8.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.16.4",
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20",
    "@types/opencc-js": "^1.0.3",
    "@types/react": "^19",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "baseline-browser-mapping": "^2.9.19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "googleapis": "^166.0.0",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.64.0"
  }
}
