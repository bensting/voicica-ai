generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model anonymous_users {
  user_id              String    @unique(map: "uq_anonymous_users_user_id") @db.VarChar(255)
  device_fingerprint   String    @unique(map: "uq_anonymous_users_device_fingerprint") @db.VarChar(255)
  ip_address           String?   @db.VarChar(50)
  user_agent           String?
  credits              Int
  total_credits_used   Int
  expires_at           DateTime? @db.Timestamptz(6)
  last_used_at         DateTime? @db.Timestamptz(6)
  is_anonymous         Boolean
  converted_to_user_id String?   @db.VarChar(255)
  id                   Int       @id(map: "pk_anonymous_users") @default(autoincrement())
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @updatedAt @db.Timestamptz(6)

  @@index([converted_to_user_id], map: "idx_anonymous_users_converted_to_user_id")
  @@index([device_fingerprint], map: "idx_anonymous_users_device_fingerprint")
  @@index([expires_at], map: "idx_anonymous_users_expires_at")
  @@index([last_used_at], map: "idx_anonymous_users_last_used_at")
  @@index([user_id], map: "idx_anonymous_users_user_id")
}

model credit_history {
  user_id      String    @db.VarChar(255)
  amount       Int
  task_id      String?   @db.VarChar(255)
  description  String
  product_type String?   @db.VarChar(50) // text_to_speech, subscription, signup_bonus, etc.
  id           Int       @id(map: "pk_credit_history") @default(autoincrement())
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @updatedAt @db.Timestamptz(6)

  @@index([created_at], map: "idx_credit_history_created_at")
  @@index([task_id], map: "idx_credit_history_task_id")
  @@index([user_id, created_at], map: "idx_credit_history_user_created")
  @@index([user_id], map: "idx_credit_history_user_id")
  @@index([product_type], map: "idx_credit_history_product_type")
}

model task_queue {
  task_id         String    @db.VarChar(255)
  task_type       String    @db.VarChar(50)
  user_id         String    @db.VarChar(255)
  status          String    @db.VarChar(20)
  priority        Int
  payload         Json      @db.Json
  retry_count     Int
  max_retries     Int
  worker_id       String?   @db.VarChar(100)
  error_message   String?
  started_at      DateTime? @db.Timestamptz(6)
  completed_at    DateTime? @db.Timestamptz(6)
  timeout_seconds Int
  id              Int       @id(map: "pk_task_queue") @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)
}

model tts_records {
  user_id         String    @db.VarChar(255)
  task_id         String    @unique(map: "ix_tts_records_task_id") @db.VarChar(255)
  text            String
  voice_name      String    @db.VarChar(255)
  language        String?   @db.VarChar(20)
  style           String?   @db.VarChar(50)
  speed           Float
  pitch           Int
  volume          Int
  credits_cost    Int
  character_count Int
  status          String    @db.VarChar(20)
  progress        Int
  audio_url       String?
  duration        Float?
  format          String    @db.VarChar(10)
  error_message   String?
  completed_at    DateTime? @db.Timestamptz(6)
  id              Int       @id(map: "pk_tts_records") @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)
  share_id        String?   @unique(map: "ix_tts_records_share_id") @db.VarChar(12)
  platform        String?   @db.VarChar(20) // web, mobile-web, android, ios

  // 关联故事（可选）
  story_id        String?
  story           stories?  @relation(fields: [story_id], references: [id], onDelete: SetNull)

  @@index([status], map: "ix_tts_records_status")
  @@index([user_id, created_at], map: "ix_tts_records_user_created")
  @@index([user_id], map: "ix_tts_records_user_id")
  @@index([user_id, status], map: "ix_tts_records_user_status")
  @@index([user_id, status, created_at], map: "ix_tts_records_user_status_created")
  @@index([story_id], map: "ix_tts_records_story_id")
  @@index([platform], map: "ix_tts_records_platform")
}

model user_subscriptions {
  user_id                  String    @db.VarChar(128)
  product_id               String    @db.VarChar(255) // 订阅计划标识，关联到配置文件
  product_type             String?   @db.VarChar(50)
  platform                 String?   @db.VarChar(50)
  external_transaction_id  String    @db.VarChar(255)
  external_subscription_id String?   @db.VarChar(255)
  request_id               String    @unique(map: "ix_user_subscriptions_request_id") @db.VarChar(100)
  status                   String    @db.VarChar(50)
  start_date               DateTime  @db.Timestamptz(6)
  end_date                 DateTime  @db.Timestamptz(6)
  credits_allocated        Int
  amount                   Int?
  currency                 String?   @db.VarChar(10)
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime  @updatedAt @db.Timestamptz(6)
  activated_at             DateTime? @db.Timestamptz(6)
  cancelled_at             DateTime? @db.Timestamptz(6)
  cancellation_reason      String?   @db.VarChar(500)
  auto_renew               Boolean
  cancel_at_period_end     Boolean
  id                       Int       @id(map: "pk_user_subscriptions") @default(autoincrement())
  users                    users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_subscriptions_user_id_users")

  @@index([end_date], map: "ix_user_subscriptions_end_date")
  @@index([platform, external_subscription_id], map: "ix_user_subscriptions_platform_ext_sub")
  @@index([platform, external_transaction_id], map: "ix_user_subscriptions_platform_ext_txn")
  @@index([product_id], map: "ix_user_subscriptions_product_id")
  @@index([status], map: "ix_user_subscriptions_status")
  @@index([status, end_date], map: "ix_user_subscriptions_status_end_date")
  @@index([user_id], map: "ix_user_subscriptions_user_id")
  @@index([user_id, status], map: "ix_user_subscriptions_user_status")

  // 关联历史记录
  history subscription_history[]
}

/// 订阅变动历史表
model subscription_history {
  id                 Int                @id @default(autoincrement())
  subscription_id    Int
  user_id            String             @db.VarChar(128)
  event_type         String             @db.VarChar(50) // CREATED, ACTIVATED, RENEWED, CANCELLED, EXPIRED, UPDATED
  old_status         String?            @db.VarChar(50)
  new_status         String?            @db.VarChar(50)
  stripe_event_id    String?            @db.VarChar(255) // Stripe event ID for deduplication
  stripe_event_type  String?            @db.VarChar(100) // checkout.session.completed, invoice.paid, etc.
  amount             Int?               // 金额（分）
  currency           String?            @db.VarChar(10)
  credits_change     Int?               // 积分变动
  metadata           Json?              // 额外信息
  created_at         DateTime           @default(now()) @db.Timestamptz(6)

  // 关联
  subscription       user_subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@unique([stripe_event_id]) // 防止重复处理
  @@index([subscription_id], map: "ix_subscription_history_subscription_id")
  @@index([user_id], map: "ix_subscription_history_user_id")
  @@index([event_type], map: "ix_subscription_history_event_type")
  @@index([created_at], map: "ix_subscription_history_created_at")
}

model users {
  user_id            String               @unique(map: "uq_users_user_id") @db.VarChar(128)
  email              String?              @db.VarChar(255)
  name               String?              @db.VarChar(255)
  photo_url          String?              @db.VarChar(500)
  phone              String?              @db.VarChar(20)
  auth_provider      String?              @db.VarChar(50) // 注册方式: google, apple, password, facebook, x 等
  platform           String?              @db.VarChar(20) // 注册平台: web, mobile-web, android, ios
  credits            Int                  // 永久积分（购买、注册赠送，永不过期）
  monthly_credits    Int                  @default(0) // 当月积分（每日任务，月初重置）
  monthly_credits_reset_at DateTime?      @db.Timestamptz(6) // 当月积分上次重置时间
  total_credits_used Int
  id                 Int                  @id(map: "pk_users") @default(autoincrement())
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @updatedAt @db.Timestamptz(6)
  user_subscriptions user_subscriptions[]

  @@index([email], map: "idx_user_email")
  @@index([user_id], map: "idx_user_id")
  @@index([platform], map: "idx_user_platform")
}

model voices {
  name              String    @unique(map: "uq_voices_name") @db.VarChar(255)
  provider          String    @db.VarChar(50)
  locale            String    @db.VarChar(20)
  country           String    @db.VarChar(10)
  role              String    @db.VarChar(50)
  gender            String    @db.VarChar(20)
  avatar_url        String
  voice_sample_url  Json      @db.Json // {style: url} 格式，如 {"default": "https://...", "calm": "https://..."}
  voice_sample_text String
  tags              Json      @db.Json
  style_list        Json      @db.Json
  is_active         Boolean
  sort_order        Int
  id                Int       @id(map: "pk_voices") @default(autoincrement())
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)
  display_name      String?   @db.VarChar(100)

  @@index([country], map: "ix_voices_country")
  @@index([is_active], map: "ix_voices_is_active")
  @@index([locale], map: "ix_voices_locale")
  @@index([locale, is_active], map: "ix_voices_locale_active")
  @@index([name], map: "ix_voices_name")
  @@index([provider], map: "ix_voices_provider")
  @@index([provider, country], map: "ix_voices_provider_country")
  @@index([role], map: "ix_voices_role")
  @@index([role, country], map: "ix_voices_role_country")
  @@index([sort_order, is_active], map: "ix_voices_sort_active")
}

/// App releases management (APK, iOS, etc.)
model app_releases {
  id             Int       @id @default(autoincrement())
  platform       String    @db.VarChar(20) // android, ios
  version        String    @db.VarChar(20) // 1.0.0
  version_code   Int       // 1, 2, 3... for version comparison
  download_url   String    // R2 URL
  file_size      BigInt?   // File size in bytes
  release_notes  String?   // Release notes / changelog
  is_latest      Boolean   @default(false) // Is this the latest version
  is_force_update Boolean  @default(false) // Force users to update
  is_active      Boolean   @default(true) // Is this release active
  download_count Int       @default(0) // Download counter
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @updatedAt @db.Timestamptz(6)

  @@unique([platform, version])
  @@index([platform, is_latest], map: "ix_app_releases_platform_latest")
  @@index([platform, is_active], map: "ix_app_releases_platform_active")
  @@index([platform, version_code], map: "ix_app_releases_platform_version_code")
}

/// Video generation records (Text-to-Video, Image-to-Video)
model video_records {
  user_id          String    @db.VarChar(255)
  task_id          String    @unique(map: "ix_video_records_task_id") @db.VarChar(255)
  external_task_id String?   @db.VarChar(255) // KIE API external task ID for webhook lookup
  task_type        String    @db.VarChar(50) // text_to_video, image_to_video
  model           String    @db.VarChar(50) // veo-3.1, etc.
  prompt          String    // User's text prompt
  prompt_zh       String?   // Translated Chinese prompt (if translation enabled)
  negative_prompt String?   // Negative prompt (optional)
  resolution      String    @db.VarChar(20) // 768p, 1080p
  duration        Int       // Target duration in seconds (8, 10, 15)
  aspect_ratio    String    @db.VarChar(10) // 16:9, 9:16
  seed            Int?      // Random seed for reproducibility
  is_public       Boolean   @default(false) // Public visibility
  credits_cost    Int       // Credits deducted
  api_cost        Float?    // Actual API cost from provider (e.g., Runware)
  status          String    @db.VarChar(20) // PENDING, PROCESSING, SUCCESS, FAILURE
  progress        Int       @default(0) // 0-100 progress indicator
  video_url       String?   // R2 URL after success
  thumbnail_url   String?   // Video thumbnail URL
  actual_duration Float?    // Actual video duration in seconds
  format          String    @db.VarChar(10) @default("mp4") // mp4
  error_message   String?
  completed_at    DateTime? @db.Timestamptz(6)
  share_id        String?   @unique(map: "ix_video_records_share_id") @db.VarChar(12)
  view_count      Int       @default(0) // Public view count
  id              Int       @id(map: "pk_video_records") @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)

  @@index([status], map: "ix_video_records_status")
  @@index([user_id], map: "ix_video_records_user_id")
  @@index([user_id, created_at], map: "ix_video_records_user_created")
  @@index([user_id, status], map: "ix_video_records_user_status")
  @@index([user_id, status, created_at], map: "ix_video_records_user_status_created")
  @@index([is_public], map: "ix_video_records_is_public")
  @@index([external_task_id], map: "ix_video_records_external_task_id")
}

/// 用户事件追踪表（通用）
model user_events {
  id         Int       @id @default(autoincrement())
  user_id    String    @db.VarChar(128)
  event      String    @db.VarChar(100) // buy_now_clicked, upgrade_modal_opened, etc.
  data       Json?     // 可选的附加数据
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "ix_user_events_user_id")
  @@index([event], map: "ix_user_events_event")
  @@index([created_at], map: "ix_user_events_created_at")
  @@index([user_id, event], map: "ix_user_events_user_event")
}

/// 每日任务表 - 签到和广告奖励
/// 每用户每天最多一条记录
model daily_tasks {
  id                    Int       @id @default(autoincrement())
  user_id               String    @db.VarChar(128)   // 登录用户ID（必须登录）
  date                  String    @db.VarChar(10)    // 格式: '2025-01-15'

  // 签到任务
  checkin_done          Boolean   @default(false)    // 是否已签到
  checkin_credits       Int       @default(0)        // 签到获得的积分

  // 广告奖励任务 - 递进式：200, 300, 400, 500, 800, 1000
  ad_rewards_claimed    Int       @default(0)        // 已领取的广告档位数 (0-6)
  ad_rewards_credits    Int       @default(0)        // 广告奖励累计获得的积分

  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @updatedAt @db.Timestamptz(6)

  @@unique([user_id, date], map: "uq_daily_tasks_user_date")
  @@index([user_id], map: "ix_daily_tasks_user_id")
  @@index([date], map: "ix_daily_tasks_date")
}

/// AdMob 激励广告奖励交易记录
/// 用于 Server-Side Verification (SSV) 防重放攻击
model ad_reward_transactions {
  id              Int       @id @default(autoincrement())
  transaction_id  String    @unique @db.VarChar(255)  // AdMob 交易 ID（唯一）
  user_id         String    @db.VarChar(128)          // 用户 ID
  tier            Int?                                 // 奖励档位（0-5 对应 200-1000）
  timestamp       DateTime  @db.Timestamptz(6)        // 广告完成时间
  ad_unit         String?   @db.VarChar(100)          // 广告单元 ID
  reward_amount   Int       @default(0)               // AdMob 配置的奖励数量
  processed       Boolean   @default(false)           // 是否已处理
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "ix_ad_reward_transactions_user_id")
  @@index([timestamp], map: "ix_ad_reward_transactions_timestamp")
  @@index([processed], map: "ix_ad_reward_transactions_processed")
}

/// AI 生成的故事
model stories {
  id                String    @id @default(cuid())
  user_id           String    @db.VarChar(128)

  // 故事内容
  title             String    @db.VarChar(500)
  content           String    @db.Text

  // 生成元数据
  keywords          String?   @db.VarChar(500)   // 生成时使用的关键词
  idea_title        String?   @db.VarChar(500)   // 选择的创意标题
  idea_description  String?   @db.Text           // 选择的创意描述
  locale            String    @default("en-US") @db.VarChar(20) // 生成语言

  // 统计
  word_count        Int       @default(0)        // 字数统计

  // 角色描述（用于保持插图角色一致性）
  character_descriptions String? @db.Text        // JSON 格式的角色描述

  // 状态
  status            String    @default("draft") @db.VarChar(20) // draft, published

  // 视频（一个故事一个视频）
  video_url         String?                      // 视频 URL
  video_status      String    @default("none") @db.VarChar(20) // none, pending, processing, completed, failed
  video_duration    Int?                         // 视频时长（秒）
  video_thumbnail   String?                      // 视频封面

  // 时间
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)

  // 关联
  paragraphs        story_paragraphs[]
  illustrations     story_illustrations[]
  tts_records       tts_records[]

  @@index([user_id], map: "ix_stories_user_id")
  @@index([status], map: "ix_stories_status")
  @@index([user_id, status], map: "ix_stories_user_status")
  @@index([user_id, created_at], map: "ix_stories_user_created")
  @@index([created_at], map: "ix_stories_created_at")
}

/// 故事插图（一个故事多个插图）
model story_illustrations {
  id          String    @id @default(cuid())
  story_id    String

  // 类型
  type        String    @default("scene") @db.VarChar(20) // cover, scene

  // 图片信息
  image_url   String?                          // 图片 URL（生成完成后填充）
  prompt      String?   @db.Text               // AI 生成提示词（英文，用于图片生成）
  scene_description String? @db.Text           // 场景描述（原文语言，用于展示）
  position    Int       @default(0)            // 在故事中的顺序
  paragraph   Int?                             // 对应第几段（可选）

  // 生成信息
  task_id     String?   @db.VarChar(255)       // Runware task ID
  width       Int       @default(1024)         // 图片宽度
  height      Int       @default(1024)         // 图片高度
  model       String?   @db.VarChar(100)       // 使用的模型
  credits_cost Int      @default(0)            // 消耗积分

  // 状态
  status      String    @default("pending") @db.VarChar(20) // pending, processing, completed, failed
  error_message String?                        // 错误信息

  // 时间
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @updatedAt @db.Timestamptz(6)

  // 关联
  story       stories   @relation(fields: [story_id], references: [id], onDelete: Cascade)

  @@index([story_id], map: "ix_story_illustrations_story_id")
  @@index([position], map: "ix_story_illustrations_position")
  @@index([status], map: "ix_story_illustrations_status")
  @@index([type], map: "ix_story_illustrations_type")
}

/// AI 音乐生成记录
model music_records {
  user_id           String    @db.VarChar(255)
  task_id           String    @unique(map: "ix_music_records_task_id") @db.VarChar(255)
  external_task_id  String?   @db.VarChar(255)  // KIE API 返回的 taskId
  model             String    @db.VarChar(50)   // music-5.0, music-4.5-plus, music-4.5
  prompt            String    @db.Text          // 用户输入的提示词
  style             String?   @db.VarChar(500)  // 音乐风格
  title             String?   @db.VarChar(200)  // 歌曲标题
  lyrics            String?   @db.Text          // 生成的歌词
  is_instrumental   Boolean   @default(false)   // 是否纯音乐
  is_custom_mode    Boolean   @default(false)   // 是否使用自定义模式
  is_public         Boolean   @default(false)   // 是否公开
  credits_cost      Int                         // 消耗积分
  status            String    @db.VarChar(20)   // PENDING, PROCESSING, SUCCESS, FAILURE
  progress          Int       @default(0)       // 0-100 进度

  // 生成结果（可能有多个音频）
  external_track_id   String?   @db.VarChar(255)  // KIE 回调的第一首歌 id
  external_track_id_2 String?   @db.VarChar(255)  // KIE 回调的第二首歌 id
  audio_url         String?                     // 主音频 URL
  audio_url_2       String?                     // 第二个音频 URL（Suno 一次生成两个）
  stream_url        String?                     // 流媒体 URL
  stream_url_2      String?                     // 第二个流媒体 URL
  cover_url         String?                     // 封面图 URL
  cover_url_2       String?                     // 第二个封面图 URL
  duration          Float?                      // 音频时长（秒）
  duration_2        Float?                      // 第二个音频时长
  tags              String?   @db.VarChar(500)  // 音乐标签

  error_message     String?
  completed_at      DateTime? @db.Timestamptz(6)
  share_id          String?   @unique(map: "ix_music_records_share_id") @db.VarChar(12)
  id                Int       @id(map: "pk_music_records") @default(autoincrement())
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)

  @@index([status], map: "ix_music_records_status")
  @@index([user_id], map: "ix_music_records_user_id")
  @@index([user_id, created_at], map: "ix_music_records_user_created")
  @@index([user_id, status], map: "ix_music_records_user_status")
  @@index([external_task_id], map: "ix_music_records_external_task_id")
  @@index([is_public], map: "ix_music_records_is_public")
}

/// 对话生成记录（ElevenLabs Text-to-Dialogue）
model dialogue_records {
  id                Int       @id @default(autoincrement())
  user_id           String    @db.VarChar(255)
  task_id           String    @unique @db.VarChar(255)
  external_task_id  String?   @db.VarChar(255)  // KIE API 返回的 taskId

  // 对话内容（JSON 格式存储多个对话片段）
  dialogue_json     String    @db.Text          // [{ text: "...", voice: "Adam" }, ...]
  total_characters  Int                         // 总字符数
  credits_cost      Int                         // 消耗积分

  // 状态
  status            String    @db.VarChar(20)   // PENDING, PROCESSING, SUCCESS, FAILURE
  progress          Int       @default(0)       // 0-100 进度

  // 生成结果
  audio_url         String?                     // 生成的音频 URL
  duration          Float?                      // 音频时长（秒）

  error_message     String?
  completed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)

  @@index([user_id], map: "ix_dialogue_records_user_id")
  @@index([user_id, created_at], map: "ix_dialogue_records_user_created")
  @@index([status], map: "ix_dialogue_records_status")
  @@index([external_task_id], map: "ix_dialogue_records_external_task_id")
}

/// RVC 声音模型（用于 AI Cover 功能）
model rvc_voice_models {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(100)           // 显示名称
  slug            String    @unique @db.VarChar(100)   // URL 友好的唯一标识
  category        String    @db.VarChar(50)            // my-clone, cartoon, music, rapper, celebrity, anime
  avatar_url      String?                              // 头像 URL
  sample_url      String?                              // 试听音频 URL
  model_url       String                               // RVC 模型下载 URL
  index_url       String?                              // RVC index 文件 URL（可选）
  uses_count      Int       @default(0)                // 使用次数
  is_builtin      Boolean   @default(false)            // 是否内置模型 (Obama, Trump, Sandy, Rogan)
  builtin_name    String?   @db.VarChar(50)            // 内置模型名称
  is_active       Boolean   @default(true)             // 是否启用
  sort_order      Int       @default(0)                // 排序
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)

  @@index([category], map: "ix_rvc_voice_models_category")
  @@index([is_active], map: "ix_rvc_voice_models_is_active")
  @@index([is_builtin], map: "ix_rvc_voice_models_is_builtin")
  @@index([sort_order], map: "ix_rvc_voice_models_sort_order")
}

/// AI Cover 生成记录
model cover_records {
  id                Int       @id @default(autoincrement())
  user_id           String    @db.VarChar(255)
  task_id           String    @unique @db.VarChar(255)

  // 输入
  original_audio_url String                            // 原始音频 URL
  voice_model_id    Int                                // 使用的声音模型 ID
  voice_model_name  String    @db.VarChar(100)         // 声音模型名称（冗余存储）

  // 参数
  pitch_change      Int       @default(0)              // 音高调整（半音）
  f0_method         String    @default("rmvpe") @db.VarChar(20) // 音高检测方法
  index_rate        Float     @default(0.5)            // AI 口音强度
  protect           Float     @default(0.33)           // 保护原始呼吸声

  // 处理状态
  status            String    @db.VarChar(20)          // PENDING, SEPARATING, CONVERTING, MERGING, SUCCESS, FAILURE
  progress          Int       @default(0)              // 0-100

  // Replicate 任务 ID
  spleeter_task_id  String?   @db.VarChar(255)         // Spleeter 人声分离任务 ID
  rvc_task_id       String?   @db.VarChar(255)         // RVC 音色转换任务 ID

  // 中间结果
  vocals_url        String?                            // 分离出的人声 URL
  accompaniment_url String?                            // 分离出的伴奏 URL
  converted_vocals_url String?                         // 转换后的人声 URL

  // 最终结果
  output_url        String?                            // 最终合成的音频 URL
  duration          Float?                             // 音频时长（秒）

  // 费用
  credits_cost      Int                                // 消耗积分
  is_public         Boolean   @default(false)          // 是否公开

  error_message     String?
  share_id          String?   @unique @db.VarChar(12)
  completed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)

  @@index([user_id], map: "ix_cover_records_user_id")
  @@index([status], map: "ix_cover_records_status")
  @@index([user_id, status], map: "ix_cover_records_user_status")
  @@index([user_id, created_at], map: "ix_cover_records_user_created")
  @@index([voice_model_id], map: "ix_cover_records_voice_model_id")
}

/// 分享链接表
model share_links {
  id            Int       @id @default(autoincrement())
  token         String    @unique @db.VarChar(32)      // 短token (nanoid)
  resource_type String    @db.VarChar(50)              // music, dialogue, tts, cover
  resource_id   String    @db.VarChar(100)             // 对应记录的 task_id
  user_id       String    @db.VarChar(128)             // 创建分享的用户
  expires_at    DateTime  @db.Timestamptz(6)           // 过期时间
  view_count    Int       @default(0)                  // 查看次数
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([token], map: "ix_share_links_token")
  @@index([resource_type, resource_id], map: "ix_share_links_resource")
  @@index([user_id], map: "ix_share_links_user_id")
  @@index([expires_at], map: "ix_share_links_expires_at")
}

/// AI 图片生成记录
model image_records {
  id                Int       @id @default(autoincrement())
  user_id           String    @db.VarChar(255)
  task_id           String    @unique @db.VarChar(255)

  // 生成参数
  model             String    @db.VarChar(100)        // seedream/4.5-text-to-image, nano-banana-pro
  prompt            String    @db.Text                // 用户输入的提示词
  aspect_ratio      String    @db.VarChar(20)         // 1:1, 16:9, 9:16, etc.
  quality           String    @db.VarChar(20)         // basic, high, 1K, 2K, 4K

  // 状态
  status            String    @db.VarChar(20)         // PENDING, PROCESSING, SUCCESS, FAILURE
  progress          Int       @default(0)             // 0-100 进度

  // 结果
  image_url         String?                           // 生成的图片 URL
  is_public         Boolean   @default(false)         // 是否公开

  // 费用
  credits_used      Int                               // 消耗积分

  error             String?                           // 错误信息
  completed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @updatedAt @db.Timestamptz(6)

  @@index([user_id], map: "ix_image_records_user_id")
  @@index([user_id, created_at], map: "ix_image_records_user_created")
  @@index([status], map: "ix_image_records_status")
  @@index([user_id, status], map: "ix_image_records_user_status")
  @@index([is_public], map: "ix_image_records_is_public")
}

/// Native App Banner 配置
model native_banners {
  id           Int       @id @default(autoincrement())
  image_url    String                              // 背景图片 URL (3:1 比例)
  link_url     String?                             // 点击跳转链接
  titles       Json      @db.Json                  // 多语言标题 {"en-US": "...", "zh-CN": "..."}
  subtitles    Json      @db.Json                  // 多语言副标题
  button_texts Json?     @db.Json                  // 多语言按钮文字（可选）
  sort_order   Int       @default(0)               // 排序（越小越靠前）
  is_active    Boolean   @default(true)            // 是否启用
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @updatedAt @db.Timestamptz(6)

  @@index([is_active, sort_order], map: "ix_native_banners_active_sort")
}

/// 故事段落（一个故事多个段落）
model story_paragraphs {
  id              String    @id @default(cuid())
  story_id        String

  // 段落内容
  position        Int       @default(0)            // 段落顺序（从0开始）
  content         String    @db.Text               // 段落文本内容

  // 音频（段落级别的 TTS）
  audio_url       String?                          // 段落音频 URL
  audio_duration  Float?                           // 音频时长（秒）
  audio_voice     String?   @db.VarChar(255)       // 使用的语音名称
  audio_status    String    @default("none") @db.VarChar(20) // none, pending, processing, completed, failed

  // 插图（段落级别）
  illustration_url    String?                      // 段落插图 URL
  illustration_prompt String?   @db.Text           // 生成插图的提示词
  illustration_status String   @default("none") @db.VarChar(20) // none, pending, processing, completed, failed

  // 时间
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @updatedAt @db.Timestamptz(6)

  // 关联
  story           stories   @relation(fields: [story_id], references: [id], onDelete: Cascade)

  @@unique([story_id, position], map: "uq_story_paragraphs_story_position")
  @@index([story_id], map: "ix_story_paragraphs_story_id")
  @@index([position], map: "ix_story_paragraphs_position")
}
