# 支付配置
# 支付平台选择: 'creem' 或 'stripe'
NEXT_PUBLIC_PAYMENT_PROVIDER=stripe

# Creem 支付配置
# 支付成功后的回调 URL (用户完成支付后跳转的页面)
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
# 支付取消后的回调 URL (用户取消支付后跳转的页面，可选)
NEXT_PUBLIC_PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

MICROSOFT_TTS_API_KEY=your_microsoft_tts_api_key
MICROSOFT_TTS_REGION=southeastasia

# Auth.js
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'));" 或者 openssl rand -base64 32
AUTH_URL=http://localhost:3000
AUTH_SECRET=your_auth_secret

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Neon Database 配置
# 注意：添加连接池参数以避免 "Error { kind: Closed }" 错误
# pgbouncer=true - 使用 Neon 连接池
# connection_limit=1 - Serverless 环境每个函数只需 1 个连接
# pool_timeout=0 - 禁用超时，避免连接关闭错误
DATABASE_URL=postgresql://neondb_owner:your_db_password@your-host.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1&pool_timeout=0

# Cloudflare R2 存储配置（如果使用 cloudflare_r2 后端）
# R2 Account ID（可在 Cloudflare Dashboard 查看）
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id
# R2 API Token 的 Access Key ID
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2 API Token 的 Secret Access Key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2 Bucket 名称
CLOUDFLARE_R2_BUCKET_NAME=ai-voice-labs
# R2 公开访问 URL（用于公开访问文件）
# 使用 Cloudflare 提供的公共开发 URL（不含 bucket 名称，会自动拼接）
CLOUDFLARE_R2_PUBLIC_URL=https://pub-dc353f0aede3432493780267c47faff7.r2.dev

# Inngest (可选，生产环境需要，claudflare)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# Video Downloader Tools API
# 用于视频解析、下载代理、缩略图代理等
# 开发环境可设为 http://localhost:8000，生产环境使用 https://tools-api.voicica.ai
NEXT_PUBLIC_TOOLS_API_URL=https://tools-api.voicica.ai